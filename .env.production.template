# Production Environment Template for Railway
# Copy this to Railway Variables tab

# === DATABASE ===
DATABASE_URL=postgresql://user:pass@host:5432/dbname?schema=public

# === SECURITY (Generate with Node.js commands below) ===
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_REFRESH_SECRET=
# Run: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY=

# === SERVER CONFIG ===
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://localhost:5173

# === JWT TIMING ===
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# === DEMO MODE (Disable paid services) ===
PAYSTACK_SECRET_KEY=demo_key
FLUTTERWAVE_SECRET_KEY=demo_key
SENDGRID_API_KEY=skip_for_demo
AWS_ACCESS_KEY_ID=skip_for_demo
AWS_SECRET_ACCESS_KEY=skip_for_demo
AGORA_APP_ID=skip_for_demo
ENABLE_VIRUS_SCAN=false

# === OPTIONAL: Sentry Error Tracking ===
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
