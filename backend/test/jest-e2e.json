{
  "displayName": "e2e",
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testRegex": "test/.*\\.e2e-spec\\.ts$",
  "setupFiles": ["<rootDir>/test/e2e-setup.ts"],
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", { "isolatedModules": true }]
  },
  "testEnvironment": "node",
  "testTimeout": 30000
}
