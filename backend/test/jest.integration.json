{
  "displayName": "integration",
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testRegex": "test/.*\\.integration\\.spec\\.ts$",
  "transform": { "^.+\\.(t|j)s$": "ts-jest" },
  "testEnvironment": "node",
  "testTimeout": 30000,
  "moduleNameMapper": {
    "^@ile-ase/common$": "<rootDir>/test/mocks/common.mock.ts"
  }
}
