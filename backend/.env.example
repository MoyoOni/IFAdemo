# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/ilease?schema=public"

# JWT Configuration (REQUIRED - generate secure random strings)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-secure-jwt-secret-at-least-32-characters"
JWT_REFRESH_SECRET="your-secure-refresh-secret-at-least-32-characters"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server Configuration
PORT=3000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"
# Production: comma-separated list of allowed origins (e.g. https://app.example.com,https://admin.example.com)
# CORS_ALLOWED_ORIGINS="https://yourapp.com"

# Message Encryption (REQUIRED - must be exactly 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY="your-32-character-encryption-key"

# AWS S3 Configuration (for document uploads)
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=your-bucket-name
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Email Service (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key

# Payment Gateways
PAYSTACK_SECRET_KEY=your-paystack-secret-key
FLUTTERWAVE_SECRET_KEY=your-flutterwave-secret-key

# Video Calls (Agora)
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-certificate

# Virus Scanning (optional)
ENABLE_VIRUS_SCAN=false

# Error Tracking (optional - set in production for Sentry)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Development Only - Quick Access Login (NEVER enable in production)
# ENABLE_QUICK_ACCESS=true
