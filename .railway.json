{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "setup": {
        "nodejs": "20"
      },
      "phases": {
        "install": {
          "command": "npm ci"
        },
        "build": {
          "command": "npm run -w @ile-ase/common build && cd backend && npx prisma generate && npm run build"
        }
      }
    }
  },
  "deploy": {
    "startCommand": "cd backend && node dist/backend/src/main.js",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 100
  }
}
