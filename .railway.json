{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "setup": {
        "nodejs": "20.x"
      },
      "phases": {
        "install": {
          "command": "cd backend && npm ci"
        },
        "build": {
          "command": "cd backend && npm run build"
        }
      }
    }
  },
  "deploy": {
    "startCommand": "cd backend && node dist/backend/src/main.js",
    "workdir": "backend",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 100
  }
}
