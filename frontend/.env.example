# API Configuration
VITE_API_URL=http://localhost:3000/api

# Demo mode: when true, API failures fall back to demo data (PB-203.3)
# Development: set to true. Production: set to false or omit (errors surface to Sentry)
VITE_DEMO_MODE=true
# Legacy alias (optional)
# VITE_ENABLE_DEMO_MODE=true

# Error Tracking (optional - set in production for Sentry)
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Third-party Services (if needed on frontend)
# VITE_AGORA_APP_ID=your-agora-app-id
