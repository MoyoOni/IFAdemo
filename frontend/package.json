    "@radix-ui/react-slot": "^1.1.0",
    "@sentry/node": "9.20.0",
    "@sentry/profiling-node": "9.20.0",
    "@sentry/react": "^10.38.0",
    "@sentry/vite-plugin": "^0.4.0",
    "@tanstack/react-query": "^5.62.9",
    "agora-rtc-sdk-ng": "^4.24.2",
    "axios": "^1.7.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
